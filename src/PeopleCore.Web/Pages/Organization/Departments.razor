@page "/departments"
@attribute [Authorize(Roles = "Admin,HRManager")]
@inject ApiClient Api

<h2 class="text-2xl font-semibold mb-4">Departments</h2>

<div class="bg-white rounded-lg shadow p-4 mb-4 flex items-end gap-3">
    <div class="flex-1">
        <label class="block text-xs font-medium text-gray-500 mb-1">Name</label>
        <input @bind="_newName" class="border rounded px-3 py-1.5 text-sm w-full max-w-xs" placeholder="Department name" />
    </div>
    <div class="flex-1">
        <label class="block text-xs font-medium text-gray-500 mb-1">Code</label>
        <input @bind="_newCode" class="border rounded px-3 py-1.5 text-sm w-full max-w-xs" placeholder="e.g. HR, FIN" />
    </div>
    <button @onclick="Create" disabled="@(_creating || string.IsNullOrWhiteSpace(_newName))"
            class="bg-blue-600 text-white px-4 py-1.5 rounded text-sm hover:bg-blue-700 disabled:opacity-50">
        @(_creating ? "Adding..." : "+ Add")
    </button>
</div>

@if (_error is not null)
{
    <div class="bg-red-50 text-red-700 rounded p-3 mb-4 text-sm">@_error</div>
}

<div class="bg-white rounded-lg shadow overflow-hidden">
    @if (_departments is null)
    {
        <div class="p-6 text-sm text-gray-400">Loading...</div>
    }
    else if (!_departments.Items.Any())
    {
        <div class="p-6 text-sm text-gray-400">No departments yet.</div>
    }
    else
    {
        <table class="w-full text-sm">
            <thead class="bg-gray-50">
                <tr class="text-left text-gray-500 text-xs uppercase">
                    <th class="px-4 py-3">Name</th>
                    <th class="px-4 py-3">Code</th>
                    <th class="px-4 py-3">Parent</th>
                    <th class="px-4 py-3">Sub-depts</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in _departments.Items)
                {
                    <tr class="border-t hover:bg-gray-50">
                        <td class="px-4 py-3 font-medium">@d.Name</td>
                        <td class="px-4 py-3 font-mono text-xs text-gray-500">@(d.Code ?? "--")</td>
                        <td class="px-4 py-3 text-gray-500">@(d.ParentDepartmentName ?? "--")</td>
                        <td class="px-4 py-3 text-gray-500">@d.SubDepartmentCount</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private PagedResult<DepartmentDto>? _departments;
    private IReadOnlyList<CompanyDto>? _companies;
    private string _newName = string.Empty;
    private string? _newCode;
    private bool _creating;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        _companies = await Api.GetCompaniesAsync();
        await Load();
    }

    private async Task Load() => _departments = await Api.GetDepartmentsAsync();

    private async Task Create()
    {
        if (string.IsNullOrWhiteSpace(_newName) || _companies is null || !_companies.Any()) return;
        _creating = true;
        _error = null;
        try
        {
            await Api.CreateDepartmentAsync(new { companyId = _companies[0].Id, name = _newName, code = _newCode, parentDepartmentId = (Guid?)null });
            _newName = string.Empty;
            _newCode = null;
            await Load();
        }
        catch { _error = "Failed to create department."; }
        finally { _creating = false; }
    }
}
