@page "/applicants"
@attribute [Authorize(Roles = "Admin,HRManager")]
@inject ApiClient Api

<h2 class="text-2xl font-semibold mb-4">Applicants</h2>

<div class="bg-white rounded-lg shadow p-4 mb-4 flex items-center gap-3">
    <select @bind="_statusFilter" @bind:after="Load" class="border rounded px-3 py-1.5 text-sm">
        <option value="">All Status</option>
        <option value="Applied">Applied</option>
        <option value="Screening">Screening</option>
        <option value="Interviewing">Interviewing</option>
        <option value="Offered">Offered</option>
        <option value="Hired">Hired</option>
        <option value="Rejected">Rejected</option>
    </select>
</div>

<div class="bg-white rounded-lg shadow overflow-hidden">
    @if (_applicants is null)
    {
        <div class="p-6 text-sm text-gray-400">Loading...</div>
    }
    else if (!_applicants.Items.Any())
    {
        <div class="p-6 text-sm text-gray-400">No applicants found.</div>
    }
    else
    {
        <table class="w-full text-sm">
            <thead class="bg-gray-50">
                <tr class="text-left text-gray-500 text-xs uppercase">
                    <th class="px-4 py-3">Applicant</th>
                    <th class="px-4 py-3">Job Posting</th>
                    <th class="px-4 py-3">Applied</th>
                    <th class="px-4 py-3">Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in _applicants.Items)
                {
                    <tr class="border-t hover:bg-gray-50">
                        <td class="px-4 py-3">
                            <div class="font-medium">@a.FirstName @a.LastName</div>
                            <div class="text-xs text-gray-400">@a.Email</div>
                        </td>
                        <td class="px-4 py-3 text-gray-500">@a.JobPostingTitle</td>
                        <td class="px-4 py-3 text-gray-500">@a.AppliedAt.ToString("MMM d, yyyy")</td>
                        <td class="px-4 py-3">
                            <span class="px-2 py-0.5 rounded-full text-xs @ApplicantStatusClass(a.Status)">@a.Status</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (_applicants.TotalPages > 1)
        {
            <div class="px-4 py-3 border-t flex items-center justify-between text-sm text-gray-500">
                <span>@_applicants.TotalCount total</span>
                <div class="flex gap-2">
                    <button @onclick="PrevPage" disabled="@(_page <= 1)" class="px-3 py-1 border rounded disabled:opacity-40 hover:bg-gray-50">Prev</button>
                    <button @onclick="NextPage" disabled="@(_page >= _applicants.TotalPages)" class="px-3 py-1 border rounded disabled:opacity-40 hover:bg-gray-50">Next</button>
                </div>
            </div>
        }
    }
</div>

@code {
    private PagedResult<ApplicantDto>? _applicants;
    private string _statusFilter = string.Empty;
    private int _page = 1;

    protected override async Task OnInitializedAsync() => await Load();
    private async Task Load() => _applicants = await Api.GetApplicantsAsync(status: string.IsNullOrEmpty(_statusFilter) ? null : _statusFilter, page: _page);
    private async Task PrevPage() { if (_page > 1) { _page--; await Load(); } }
    private async Task NextPage() { if (_applicants is not null && _page < _applicants.TotalPages) { _page++; await Load(); } }

    private static string ApplicantStatusClass(string status) => status switch
    {
        "Hired" => "bg-green-100 text-green-700",
        "Rejected" => "bg-red-100 text-red-700",
        "Interviewing" => "bg-blue-100 text-blue-700",
        _ => "bg-gray-100 text-gray-600"
    };
}
