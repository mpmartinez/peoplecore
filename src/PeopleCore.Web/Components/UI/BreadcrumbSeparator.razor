@namespace IAS.Client.Components.UI

<li role="presentation" aria-hidden="true" class="@GetClasses()">
    @if (ChildContent != null)
    {
        @ChildContent
    }
    else
    {
        <svg class="size-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m9 18 6-6-6-6"/>
        </svg>
    }
</li>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }

    private string BaseClasses => "[&>svg]:size-3.5";

    private string GetClasses()
    {
        return $"{BaseClasses} {Class}".Trim();
    }
}
