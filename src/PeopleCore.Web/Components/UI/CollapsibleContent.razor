@namespace IAS.Client.Components.UI

@if (Parent?.Open == true)
{
    <div class="@GetClasses()"
         data-state="open"
         @attributes="AdditionalAttributes">
        @ChildContent
    </div>
}

@code {
    [CascadingParameter] public Collapsible? Parent { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string BaseClasses => "overflow-hidden data-[state=closed]:animate-collapsible-up data-[state=open]:animate-collapsible-down";

    private string GetClasses()
    {
        return $"{BaseClasses} {Class}".Trim();
    }
}
