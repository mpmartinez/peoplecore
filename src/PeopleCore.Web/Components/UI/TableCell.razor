@namespace IAS.Client.Components.UI

<td class="@GetClasses()" @attributes="AdditionalAttributes">
    @ChildContent
</td>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string BaseClasses => "p-2 align-middle [&:has([role=checkbox])]:pr-0 [&>[role=checkbox]]:translate-y-[2px]";

    private string GetClasses()
    {
        return $"{BaseClasses} {Class}".Trim();
    }
}
