@namespace IAS.Client.Components.UI

<div class="flex justify-between py-2 border-b border-dashed last:border-0">
    <span class="text-muted-foreground text-sm">@Label</span>
    <span class="text-sm font-medium text-right">@(string.IsNullOrEmpty(Value) ? "-" : Value)</span>
</div>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter] public string? Value { get; set; }
}
