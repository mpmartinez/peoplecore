@namespace IAS.Client.Components.UI

<div class="relative @Class" role="region" aria-roledescription="carousel" @attributes="AdditionalAttributes">
    <div class="overflow-hidden">
        <div class="flex transition-transform duration-300 ease-in-out"
             style="transform: translateX(-@(_currentIndex * 100)%)">
            <CascadingValue Value="this">
                @ChildContent
            </CascadingValue>
        </div>
    </div>

    @if (ShowArrows && _itemCount > 1)
    {
        <!-- Previous Button -->
        <button type="button"
                class="@GetArrowClasses() absolute left-2 top-1/2 -translate-y-1/2"
                disabled="@(!Loop && _currentIndex == 0)"
                @onclick="Previous">
            <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m15 18-6-6 6-6"/>
            </svg>
            <span class="sr-only">Previous slide</span>
        </button>

        <!-- Next Button -->
        <button type="button"
                class="@GetArrowClasses() absolute right-2 top-1/2 -translate-y-1/2"
                disabled="@(!Loop && _currentIndex >= _itemCount - 1)"
                @onclick="Next">
            <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m9 18 6-6-6-6"/>
            </svg>
            <span class="sr-only">Next slide</span>
        </button>
    }

    @if (ShowDots && _itemCount > 1)
    {
        <!-- Dots Indicator -->
        <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-1">
            @for (var i = 0; i < _itemCount; i++)
            {
                var index = i;
                <button type="button"
                        class="@GetDotClasses(index)"
                        @onclick="() => GoToSlide(index)">
                    <span class="sr-only">Go to slide @(index + 1)</span>
                </button>
            }
        </div>
    }
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public bool ShowArrows { get; set; } = true;
    [Parameter] public bool ShowDots { get; set; } = true;
    [Parameter] public bool Loop { get; set; } = false;
    [Parameter] public bool AutoPlay { get; set; } = false;
    [Parameter] public int AutoPlayInterval { get; set; } = 5000;
    [Parameter] public int CurrentIndex { get; set; } = 0;
    [Parameter] public EventCallback<int> CurrentIndexChanged { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private int _currentIndex;
    private int _itemCount;
    private System.Threading.Timer? _autoPlayTimer;

    protected override void OnInitialized()
    {
        _currentIndex = CurrentIndex;

        if (AutoPlay)
        {
            StartAutoPlay();
        }
    }

    protected override void OnParametersSet()
    {
        if (_currentIndex != CurrentIndex)
        {
            _currentIndex = CurrentIndex;
        }
    }

    internal void RegisterItem()
    {
        _itemCount++;
        StateHasChanged();
    }

    internal void UnregisterItem()
    {
        _itemCount--;
        if (_currentIndex >= _itemCount && _itemCount > 0)
        {
            _currentIndex = _itemCount - 1;
        }
        StateHasChanged();
    }

    private string GetArrowClasses()
    {
        return "inline-flex items-center justify-center rounded-full bg-background/80 backdrop-blur-sm border shadow-sm h-8 w-8 hover:bg-accent hover:text-accent-foreground disabled:opacity-50 disabled:cursor-not-allowed transition-colors";
    }

    private string GetDotClasses(int index)
    {
        var isActive = index == _currentIndex;
        var baseClass = "h-2 w-2 rounded-full transition-colors";
        return isActive
            ? $"{baseClass} bg-primary"
            : $"{baseClass} bg-primary/30 hover:bg-primary/50";
    }

    private async Task Previous()
    {
        if (_currentIndex > 0)
        {
            _currentIndex--;
        }
        else if (Loop)
        {
            _currentIndex = _itemCount - 1;
        }

        await CurrentIndexChanged.InvokeAsync(_currentIndex);
    }

    private async Task Next()
    {
        if (_currentIndex < _itemCount - 1)
        {
            _currentIndex++;
        }
        else if (Loop)
        {
            _currentIndex = 0;
        }

        await CurrentIndexChanged.InvokeAsync(_currentIndex);
    }

    private async Task GoToSlide(int index)
    {
        if (index >= 0 && index < _itemCount)
        {
            _currentIndex = index;
            await CurrentIndexChanged.InvokeAsync(_currentIndex);
        }
    }

    private void StartAutoPlay()
    {
        _autoPlayTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await Next();
                StateHasChanged();
            });
        }, null, AutoPlayInterval, AutoPlayInterval);
    }

    public void Dispose()
    {
        _autoPlayTimer?.Dispose();
    }
}
