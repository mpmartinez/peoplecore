@namespace IAS.Client.Components.UI
@inject IJSRuntime JS

<div class="relative inline-block text-left @Class" @attributes="AdditionalAttributes">
    <div @onclick="Toggle" @onclick:stopPropagation="true">
        @Trigger
    </div>

    @if (_isOpen)
    {
        <!-- Backdrop for closing -->
        <div class="fixed inset-0 z-40" @onclick="Close"></div>

        <!-- Menu Content -->
        <div class="@GetContentClasses()" role="menu" aria-orientation="vertical">
            @ChildContent
        </div>
    }
</div>

@code {
    [Parameter] public RenderFragment? Trigger { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string Align { get; set; } = "end"; // start, center, end
    [Parameter] public string Side { get; set; } = "bottom"; // top, bottom
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool _isOpen;

    private void Toggle()
    {
        _isOpen = !_isOpen;
    }

    private void Close()
    {
        _isOpen = false;
    }

    internal void CloseMenu()
    {
        Close();
        StateHasChanged();
    }

    private string ContentBaseClasses => "absolute z-50 min-w-[12rem] overflow-hidden rounded-md border bg-popover p-1 text-popover-foreground shadow-md data-[state=open]:animate-in data-[state=closed]:animate-out data-[state=closed]:fade-out-0 data-[state=open]:fade-in-0 data-[state=closed]:zoom-out-95 data-[state=open]:zoom-in-95";

    private string GetAlignClasses() => Align switch
    {
        "start" => "left-0",
        "center" => "left-1/2 -translate-x-1/2",
        "end" => "right-0",
        _ => "right-0"
    };

    private string GetSideClasses() => Side switch
    {
        "top" => "bottom-full mb-2",
        "bottom" => "top-full mt-2",
        _ => "top-full mt-2"
    };

    private string GetContentClasses()
    {
        return $"{ContentBaseClasses} {GetAlignClasses()} {GetSideClasses()}".Trim();
    }
}
