@namespace IAS.Client.Components.UI.InputOTP

<div class="flex items-center gap-2 @Class" @attributes="AdditionalAttributes">
    <CascadingValue Value="this">
        @ChildContent
    </CascadingValue>
</div>

<input type="hidden"
       @ref="_hiddenInput"
       value="@Value"
       maxlength="@MaxLength"
       @oninput="HandleInput"
       @onkeydown="HandleKeyDown"
       @onpaste="HandlePaste"
       autocomplete="one-time-code"
       inputmode="numeric"
       style="position: absolute; opacity: 0; pointer-events: none;" />

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public int MaxLength { get; set; } = 6;
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public EventCallback<string> OnComplete { get; set; }
    [Parameter] public string Pattern { get; set; } = "digits"; // digits, alphanumeric
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private ElementReference _hiddenInput;
    private int _activeIndex = 0;
    private List<InputOTPSlot> _slots = new();

    internal int ActiveIndex => _activeIndex;
    internal string CurrentValue => Value;
    internal bool IsDisabled => Disabled;

    internal void RegisterSlot(InputOTPSlot slot)
    {
        if (!_slots.Contains(slot))
        {
            _slots.Add(slot);
        }
    }

    internal void UnregisterSlot(InputOTPSlot slot)
    {
        _slots.Remove(slot);
    }

    internal char? GetCharAtIndex(int index)
    {
        if (index >= 0 && index < Value.Length)
        {
            return Value[index];
        }
        return null;
    }

    internal async Task FocusSlot(int index)
    {
        _activeIndex = Math.Clamp(index, 0, MaxLength - 1);
        StateHasChanged();
        NotifySlots();
    }

    private async Task HandleInput(ChangeEventArgs e)
    {
        var newValue = e.Value?.ToString() ?? "";
        newValue = FilterInput(newValue);

        if (newValue.Length > MaxLength)
        {
            newValue = newValue.Substring(0, MaxLength);
        }

        Value = newValue;
        await ValueChanged.InvokeAsync(Value);

        _activeIndex = Math.Min(newValue.Length, MaxLength - 1);
        NotifySlots();

        if (newValue.Length == MaxLength)
        {
            await OnComplete.InvokeAsync(Value);
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (Disabled) return;

        switch (e.Key)
        {
            case "Backspace":
                if (Value.Length > 0)
                {
                    Value = Value.Substring(0, Value.Length - 1);
                    await ValueChanged.InvokeAsync(Value);
                    _activeIndex = Math.Max(0, Value.Length);
                    NotifySlots();
                }
                break;
            case "ArrowLeft":
                _activeIndex = Math.Max(0, _activeIndex - 1);
                NotifySlots();
                break;
            case "ArrowRight":
                _activeIndex = Math.Min(MaxLength - 1, _activeIndex + 1);
                NotifySlots();
                break;
        }
    }

    private async Task HandlePaste(ClipboardEventArgs e)
    {
        // Paste handling is done through the input event
    }

    private string FilterInput(string input)
    {
        return Pattern switch
        {
            "digits" => new string(input.Where(char.IsDigit).ToArray()),
            "alphanumeric" => new string(input.Where(char.IsLetterOrDigit).ToArray()),
            _ => input
        };
    }

    private void NotifySlots()
    {
        foreach (var slot in _slots)
        {
            slot.Refresh();
        }
    }

    public async Task Focus()
    {
        _activeIndex = Math.Min(Value.Length, MaxLength - 1);
        NotifySlots();
    }

    public async Task Clear()
    {
        Value = "";
        await ValueChanged.InvokeAsync(Value);
        _activeIndex = 0;
        NotifySlots();
    }
}
