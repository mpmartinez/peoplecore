@namespace IAS.Client.Components.UI

<div class="relative @Class" @attributes="AdditionalAttributes">
    <!-- Trigger Button -->
    <button type="button"
            class="@GetTriggerClasses()"
            disabled="@Disabled"
            @onclick="Toggle">
        <svg class="mr-2 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M8 2v4"/>
            <path d="M16 2v4"/>
            <rect width="18" height="18" x="3" y="4" rx="2"/>
            <path d="M3 10h18"/>
        </svg>
        @if (Value.HasValue)
        {
            <span>@Value.Value.ToString(Format)</span>
        }
        else
        {
            <span class="text-muted-foreground">@Placeholder</span>
        }
    </button>

    <!-- Calendar Popover -->
    @if (_isOpen)
    {
        <div class="fixed inset-0 z-40" @onclick="Close"></div>
        <div class="absolute z-50 mt-2 rounded-md border bg-popover p-0 text-popover-foreground shadow-md outline-none data-[state=open]:animate-in data-[state=closed]:animate-out data-[state=closed]:fade-out-0 data-[state=open]:fade-in-0 data-[state=closed]:zoom-out-95 data-[state=open]:zoom-in-95 @GetPopoverPositionClasses()">
            <Calendar Value="@Value"
                      ValueChanged="HandleDateSelected"
                      MinDate="@MinDate"
                      MaxDate="@MaxDate"
                      DisabledDates="@DisabledDates" />
        </div>
    }
</div>

@code {
    [Parameter] public DateTime? Value { get; set; }
    [Parameter] public EventCallback<DateTime?> ValueChanged { get; set; }
    [Parameter] public string Placeholder { get; set; } = "Pick a date";
    [Parameter] public string Format { get; set; } = "PPP";
    [Parameter] public DateTime? MinDate { get; set; }
    [Parameter] public DateTime? MaxDate { get; set; }
    [Parameter] public Func<DateTime, bool>? DisabledDates { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool HasError { get; set; }
    [Parameter] public string Align { get; set; } = "start"; // start, center, end
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool _isOpen;

    private string TriggerBaseClasses => "flex h-9 w-full items-center justify-start whitespace-nowrap rounded-md border border-input bg-transparent px-3 py-2 text-sm shadow-sm ring-offset-background focus:outline-none focus:ring-1 focus:ring-ring disabled:cursor-not-allowed disabled:opacity-50 [&>span]:line-clamp-1";

    private string GetTriggerClasses()
    {
        var errorClass = HasError ? "border-destructive focus:ring-destructive" : "";
        return $"{TriggerBaseClasses} {errorClass}".Trim();
    }

    private string GetPopoverPositionClasses() => Align switch
    {
        "center" => "left-1/2 -translate-x-1/2",
        "end" => "right-0",
        _ => "left-0"
    };

    private void Toggle()
    {
        if (!Disabled)
        {
            _isOpen = !_isOpen;
        }
    }

    private void Close()
    {
        _isOpen = false;
    }

    private async Task HandleDateSelected(DateTime? date)
    {
        Value = date;
        await ValueChanged.InvokeAsync(date);
        Close();
    }

    protected override void OnParametersSet()
    {
        // Convert format string from date-fns style to .NET style
        Format = Format switch
        {
            "PPP" => "MMMM d, yyyy",
            "PP" => "MMM d, yyyy",
            "P" => "MM/dd/yyyy",
            _ => Format
        };
    }
}
