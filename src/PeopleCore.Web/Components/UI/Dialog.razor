@namespace IAS.Client.Components.UI

@if (IsOpen)
{
    <!-- Portal-like rendering at fixed position -->
    <div style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 9998; background-color: rgba(0, 0, 0, 0.8);"
         @onclick="HandleOverlayClick">
    </div>

    <!-- Modal Content - centered with explicit dimensions -->
    <div style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 9999; width: 90%; max-height: 90vh; @GetMaxWidthStyle()"
         class="relative bg-background border rounded-lg shadow-xl p-6 flex flex-col @Class"
         @onclick:stopPropagation="true"
         @attributes="AdditionalAttributes">

        <!-- Close Button -->
        <button type="button"
                @onclick="OnClose"
                class="absolute right-4 top-4 rounded-sm opacity-70 ring-offset-background transition-opacity hover:opacity-100 focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2">
            <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 6 6 18"/>
                <path d="m6 6 12 12"/>
            </svg>
            <span class="sr-only">Close</span>
        </button>

        <!-- Header -->
        @if (Title != null || Description != null)
        {
            <div class="shrink-0 flex flex-col space-y-1.5 text-center sm:text-left mb-4 pr-8">
                @if (Title != null)
                {
                    <h2 class="text-lg font-semibold leading-none tracking-tight">@Title</h2>
                }
                @if (Description != null)
                {
                    <p class="text-sm text-muted-foreground">@Description</p>
                }
            </div>
        }

        <!-- Body -->
        <div class="flex-1 overflow-y-auto @(string.IsNullOrEmpty(BodyClass) ? "" : BodyClass)">
            @ChildContent
        </div>

        <!-- Footer -->
        @if (FooterContent != null)
        {
            <div class="shrink-0">
                @FooterContent
            </div>
        }
    </div>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Description { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? FooterContent { get; set; }
    [Parameter] public string Size { get; set; } = "md";
    [Parameter] public bool CloseOnOverlayClick { get; set; } = true;
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? BodyClass { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string GetMaxWidthStyle() => Size switch
    {
        "sm" => "max-width: 384px;",
        "md" => "max-width: 512px;",
        "lg" => "max-width: 672px;",
        "xl" => "max-width: 896px;",
        "full" => "max-width: calc(100% - 2rem);",
        _ => "max-width: 512px;"
    };

    private async Task HandleOverlayClick()
    {
        if (CloseOnOverlayClick)
        {
            await OnClose.InvokeAsync();
            await IsOpenChanged.InvokeAsync(false);
        }
    }
}
